# ─── Configuration serveur Cursus ─────────────────────────────────────────────

# Port d'écoute du serveur Express
PORT=3001

# Secret JWT - CHANGEZ cette valeur en production !
JWT_SECRET=changeme-very-secret-key-change-in-production

# Origine autorisée pour CORS (mettre l'URL de votre app Electron en prod)
# En développement, * autorise toutes les origines
CORS_ORIGIN=*

# Chemin absolu vers la base SQLite
# Exemple Linux/macOS : /home/user/cursus/cursus.db
# Exemple Windows     : C:/Users/user/cursus/cursus.db
DB_PATH=/var/www/cursus/cursus.db

# Repertoire pour les uploads de documents
# Utilisez un chemin absolu ou relatif. Docker utilise /data/uploads
UPLOAD_DIR=uploads

# URL du serveur pour le frontend (utilisee en mode PWA/web)
# Exemple : https://app.cursus.school ou http://localhost:3001
VITE_SERVER_URL=http://localhost:3001

# ─── Jitsi Meet (visio libre integree au booking) ─────────────────────────────
# Override l'instance Jitsi utilisee quand use_jitsi=1 sur un type d'evenement.
# Par defaut on utilise l'instance publique gratuite de 8x8.
# Si tu self-hostes Jitsi (ex: meet.cursus.school), positionne cette var :
# JITSI_BASE_URL=https://meet.jit.si

# ─── Cloudflare Turnstile (anti-spam booking public) ──────────────────────────
# Active la verification anti-spam sur les reservations via lien public ouvert
# (`/book/e/:slug`). Sans ces variables, le captcha n'est ni affiche cote front
# ni verifie cote backend (utile en dev/tests).
# Obtenir une paire site-key / secret-key gratuitement :
#   https://dash.cloudflare.com/?to=/:account/turnstile
# La site-key est publique (incrustee dans le bundle frontend), la secret-key
# doit rester cote serveur.
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxx
# TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxx
